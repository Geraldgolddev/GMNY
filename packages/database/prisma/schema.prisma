// ─────────────────────────────────────────────────────────────────────────
// GMNY — Prisma schema (core domain)
//
// Design principles:
//  * Money uses PostgreSQL `Decimal` (exact numeric) — never floats.
//  * `Transaction` is the immutable ledger; `Wallet.balance` is the cached
//    spendable balance kept in sync by ledger writes inside a transaction.
//  * Every state-changing action is captured in `AuditLog` for compliance.
//  * Auth (RefreshToken/VerificationToken) and compliance (KycProfile/
//    ComplianceFlag) tables support the identity + KYC layers.
// ─────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DISABLED
}

enum KycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum Currency {
  USD
  USDC
  NGN
}

enum BlockchainNetwork {
  BASE_MAINNET
  BASE_SEPOLIA
}

enum WalletType {
  USER
  TREASURY
}

enum WalletStatus {
  PENDING
  ACTIVE
  FROZEN
  CLOSED
}

enum TransferStatus {
  DRAFT
  QUOTE_LOCKED
  PENDING
  AWAITING_FUNDING
  FUNDED
  ON_CHAIN_PENDING
  ON_CHAIN_CONFIRMED
  PAYOUT_PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_DEBIT
  TRANSFER_CREDIT
  FEE
  REFUND
  TREASURY_REBALANCE
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
  REVERSED
}

enum AuditAction {
  AUTH_REGISTER
  AUTH_LOGIN
  AUTH_LOGOUT
  AUTH_REFRESH
  AUTH_PASSWORD_CHANGE
  AUTH_EMAIL_VERIFY
  AUTH_EMAIL_VERIFICATION_SENT
  AUTH_FORGOT_PASSWORD
  AUTH_RESET_PASSWORD
  AUTH_SESSION_REVOKE
  USER_UPDATE
  USER_ROLE_CHANGE
  USER_STATUS_CHANGE
  WALLET_CREATE
  RECIPIENT_CREATE
  RECIPIENT_UPDATE
  RECIPIENT_DELETE
  TRANSFER_CREATE
  TRANSFER_STATUS_CHANGE
  EXCHANGE_RATE_CREATE
  KYC_STATUS_CHANGE
  ADMIN_ACTION
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ── Identity & Access ──────────────────────────────────────────────────────

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique
  passwordHash    String
  firstName       String
  lastName        String
  phone           String?
  role            UserRole   @default(USER)
  status          UserStatus @default(PENDING)
  kycStatus       KycStatus  @default(NOT_STARTED)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  profile            UserProfile?
  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]
  wallets            Wallet[]
  recipients         Recipient[]
  transfers          Transfer[]
  notifications      Notification[]
  kycProfile         KycProfile?
  auditLogs          AuditLog[]

  @@index([status])
  @@index([role])
  @@map("users")
}

/// Extended personal details (KYC-lite), kept 1:1 to isolate PII.
model UserProfile {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @db.Uuid
  address     String?
  city        String?
  state       String?
  country     String?
  dateOfBirth DateTime?
  occupation  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

/// Persisted, hashed refresh tokens enable rotation + server-side revocation.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// Single-use, hashed, expiring tokens for email verification & password reset.
model VerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  type       TokenType
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@map("verification_tokens")
}

// ── Compliance / KYC ───────────────────────────────────────────────────────

model KycProfile {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @db.Uuid
  status        KycStatus @default(NOT_STARTED)
  provider      String?
  providerRef   String?
  documents     Json?
  riskScore     Int?
  reviewedById  String?   @db.Uuid
  reviewedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  complianceFlags ComplianceFlag[]

  @@index([status])
  @@map("kyc_profiles")
}

model ComplianceFlag {
  id           String   @id @default(uuid()) @db.Uuid
  kycProfileId String   @db.Uuid
  code         String
  severity     String
  description  String?
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())

  kycProfile KycProfile @relation(fields: [kycProfileId], references: [id], onDelete: Cascade)

  @@index([kycProfileId])
  @@map("compliance_flags")
}

// ── Wallets, Treasury & Ledger ─────────────────────────────────────────────

model Wallet {
  id             String            @id @default(uuid()) @db.Uuid
  userId         String?           @db.Uuid
  type           WalletType        @default(USER)
  blockchain     BlockchainNetwork @default(BASE_SEPOLIA)
  currency       Currency          @default(USDC)
  circleWalletId String?
  address        String?
  balance        Decimal           @default(0) @db.Decimal(24, 6)
  status         WalletStatus      @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user            User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  treasuryAccount TreasuryAccount?

  @@index([userId])
  @@index([type])
  @@map("wallets")
}

model TreasuryAccount {
  id         String            @id @default(uuid()) @db.Uuid
  walletId   String            @unique @db.Uuid
  label      String
  blockchain BlockchainNetwork
  currency   Currency
  createdAt  DateTime          @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("treasury_accounts")
}

model Recipient {
  id            String   @id @default(uuid()) @db.Uuid
  ownerId       String   @db.Uuid
  fullName      String
  bankName      String
  accountNumber String
  bankCode      String
  country       String   @default("NG")
  currency      Currency @default(NGN)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  transfers Transfer[]

  @@index([ownerId])
  @@map("recipients")
}

// ── Exchange Rates ─────────────────────────────────────────────────────────

/// USD→NGN rate snapshots. `usd` is the base units (normally 1) and `ngn` is
/// the NGN value of that base; the effective rate is `ngn / usd`.
model ExchangeRate {
  id         String   @id @default(uuid()) @db.Uuid
  usd        Decimal  @default(1) @db.Decimal(18, 6)
  ngn        Decimal  @db.Decimal(18, 6)
  source     String
  timestamp  DateTime @default(now())
  validUntil DateTime

  transfers Transfer[]

  @@index([timestamp])
  @@map("exchange_rates")
}

// ── Transfers ──────────────────────────────────────────────────────────────

model Transfer {
  id              String         @id @default(uuid()) @db.Uuid
  reference       String         @unique
  senderId        String         @db.Uuid
  recipientId     String?        @db.Uuid
  exchangeRateId  String?        @db.Uuid
  amountUSD       Decimal        @db.Decimal(18, 2)
  exchangeRate    Decimal        @db.Decimal(18, 6)
  amountNGN       Decimal        @db.Decimal(18, 2)
  fee             Decimal        @default(0) @db.Decimal(18, 2)
  status          TransferStatus @default(DRAFT)
  blockchainTxHash String?
  failureReason   String?
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  sender             User                @relation(fields: [senderId], references: [id], onDelete: Cascade)
  recipient          Recipient?          @relation(fields: [recipientId], references: [id])
  exchangeRateRef    ExchangeRate?       @relation(fields: [exchangeRateId], references: [id])
  transactions       Transaction[]
  onChainTransaction OnChainTransaction?

  @@index([senderId])
  @@index([status])
  @@index([createdAt])
  @@map("transfers")
}

model OnChainTransaction {
  id            String            @id @default(uuid()) @db.Uuid
  transferId    String            @unique @db.Uuid
  blockchain    BlockchainNetwork
  txHash        String            @unique
  fromAddress   String
  toAddress     String
  amount        Decimal           @db.Decimal(24, 6)
  confirmations Int               @default(0)
  status        TransactionStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("onchain_transactions")
}

/// Immutable ledger entry — every balance movement is recorded here.
model Transaction {
  id         String            @id @default(uuid()) @db.Uuid
  transferId String?           @db.Uuid
  walletId   String?           @db.Uuid
  type       TransactionType
  amount     Decimal           @db.Decimal(24, 6)
  currency   Currency
  status     TransactionStatus @default(PENDING)
  reference  String            @unique
  metadata   Json?
  createdAt  DateTime          @default(now())

  transfer Transfer? @relation(fields: [transferId], references: [id], onDelete: Cascade)
  wallet   Wallet?   @relation(fields: [walletId], references: [id])

  @@index([transferId])
  @@index([walletId])
  @@index([type])
  @@map("transactions")
}

// ── Notifications ──────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// ── Audit ──────────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @db.Uuid
  action     AuditAction
  entityType String?
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

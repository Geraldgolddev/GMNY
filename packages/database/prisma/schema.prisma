generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AuditAction {
  USER_REGISTERED
  USER_LOGIN
  USER_LOGOUT
  TOKEN_REFRESHED
  RECIPIENT_CREATED
  RECIPIENT_UPDATED
  RECIPIENT_DELETED
  TRANSFER_CREATED
  TRANSFER_COMPLETED
  TRANSFER_FAILED
  WALLET_CREATED
  CIRCLE_TRANSFER_CREATED
  CIRCLE_TRANSFER_UPDATED
  USER_ACTIVATED
  USER_DEACTIVATED
}

enum WalletProvider {
  CIRCLE
}

enum WalletChain {
  BASE
  BASE_SEPOLIA
}

enum WalletStatus {
  CREATING
  LIVE
  FAILED
}

enum TransferStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum TransferDirection {
  USD_TO_NGN
  NGN_TO_USD
}

enum TransactionType {
  TRANSFER
  FEE
  FX_CONVERSION
}

enum TransactionStatus {
  PENDING
  SETTLED
  FAILED
}

enum NotificationType {
  TRANSFER_CREATED
  TRANSFER_COMPLETED
  TRANSFER_FAILED
  WALLET_CREATED
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(320)
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name") @db.VarChar(100)
  lastName     String    @map("last_name") @db.VarChar(100)
  role         Role      @default(USER)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  recipients    Recipient[]
  transfers     Transfer[]
  transactions  Transaction[]
  wallets       Wallet[]
  notifications Notification[]

  @@index([role])
  @@map("users")
}

/// In-app / outbound notification records for transfer and account events.
model Notification {
  id             String                     @id @default(uuid()) @db.Uuid
  userId         String                     @map("user_id") @db.Uuid
  type           NotificationType
  channel        NotificationChannel        @default(IN_APP)
  deliveryStatus NotificationDeliveryStatus @default(PENDING) @map("delivery_status")
  title          String                     @db.VarChar(200)
  body           String                     @db.VarChar(1000)
  entityType     String?                    @map("entity_type") @db.VarChar(64)
  entityId       String?                    @map("entity_id") @db.VarChar(64)
  metadata       Json?
  readAt         DateTime?                  @map("read_at")
  sentAt         DateTime?                  @map("sent_at")
  failureReason  String?                    @map("failure_reason") @db.VarChar(1000)
  createdAt      DateTime                   @default(now()) @map("created_at")
  updatedAt      DateTime                   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([deliveryStatus])
  @@index([type])
  @@map("notifications")
}

/// Custodial USDC wallet provisioned via Circle (sandbox or production).
model Wallet {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  provider         WalletProvider @default(CIRCLE)
  providerWalletId String         @unique @map("provider_wallet_id") @db.VarChar(128)
  walletSetId      String?        @map("wallet_set_id") @db.VarChar(128)
  address          String         @db.VarChar(128)
  chain            WalletChain
  currency         String         @default("USDC") @db.VarChar(16)
  status           WalletStatus   @default(LIVE)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, chain])
  @@index([userId])
  @@index([address])
  @@map("wallets")
}


model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent") @db.VarChar(512)
  ipAddress String?   @map("ip_address") @db.VarChar(64)
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  actorId    String?     @map("actor_id") @db.Uuid
  action     AuditAction
  entityType String      @map("entity_type") @db.VarChar(64)
  entityId   String?     @map("entity_id") @db.VarChar(64)
  ipAddress  String?     @map("ip_address") @db.VarChar(64)
  userAgent  String?     @map("user_agent") @db.VarChar(512)
  metadata   Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Nigerian (and future) payout destinations owned by a user.
model Recipient {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  label         String?  @db.VarChar(100)
  accountName   String   @map("account_name") @db.VarChar(255)
  accountNumber String   @map("account_number") @db.VarChar(20)
  bankName      String   @map("bank_name") @db.VarChar(255)
  bankCode      String?  @map("bank_code") @db.VarChar(20)
  country       String   @default("NG") @db.Char(2)
  currency      String   @default("NGN") @db.VarChar(16)
  isDefault     Boolean  @default(false) @map("is_default")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  transfers Transfer[]

  @@unique([userId, accountNumber, bankName])
  @@index([userId, isActive])
  @@map("recipients")
}


/// Cached FX rates. `rate` means 1 unit of baseCurrency = rate quoteCurrency.
model ExchangeRate {
  id           String   @id @default(uuid()) @db.Uuid
  pair         String   @unique @db.VarChar(16) // USDNGN
  baseCurrency String   @map("base_currency") @db.VarChar(8)
  quoteCurrency String  @map("quote_currency") @db.VarChar(8)
  rate         Decimal  @db.Decimal(18, 6)
  source       String   @db.VarChar(64)
  fetchedAt    DateTime @map("fetched_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([fetchedAt])
  @@map("exchange_rates")
}

model Transfer {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  recipientId      String            @map("recipient_id") @db.Uuid
  direction        TransferDirection @default(USD_TO_NGN)
  status           TransferStatus    @default(PENDING)
  sourceCurrency   String            @map("source_currency") @db.VarChar(8)
  sourceAmount     Decimal           @map("source_amount") @db.Decimal(18, 2)
  destCurrency     String            @map("dest_currency") @db.VarChar(8)
  destAmount       Decimal           @map("dest_amount") @db.Decimal(18, 2)
  fxRate           Decimal           @map("fx_rate") @db.Decimal(18, 6)
  feeAmount        Decimal           @map("fee_amount") @db.Decimal(18, 2)
  feeCurrency      String            @default("USD") @map("fee_currency") @db.VarChar(8)
  fxSource         String            @map("fx_source") @db.VarChar(64)
  idempotencyKey   String            @unique @map("idempotency_key") @db.VarChar(128)
  settlementRef    String?           @map("settlement_ref") @db.VarChar(128)
  settlementProvider String          @default("INTERNAL") @map("settlement_provider") @db.VarChar(32)
  /// Base / Base Sepolia when the USDC leg is on-chain.
  chain            WalletChain?
  txHash           String?           @map("tx_hash") @db.VarChar(128)
  usdcAmount       Decimal?          @map("usdc_amount") @db.Decimal(18, 6)
  note             String?           @db.VarChar(500)
  failureReason    String?           @map("failure_reason") @db.VarChar(1000)
  completedAt      DateTime?         @map("completed_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  recipient    Recipient     @relation(fields: [recipientId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@index([userId, createdAt])
  @@index([status])
  @@index([recipientId])
  @@index([txHash])
  @@map("transfers")
}

model Transaction {
  id          String            @id @default(uuid()) @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  transferId  String?           @map("transfer_id") @db.Uuid
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  currency    String            @db.VarChar(8)
  amount      Decimal           @db.Decimal(18, 8)
  description String            @db.VarChar(500)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  transfer Transfer? @relation(fields: [transferId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([transferId])
  @@index([type, status])
  @@map("transactions")
}

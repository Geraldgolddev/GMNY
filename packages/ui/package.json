{
  "name": "@nairaflow/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared React UI component library (shadcn/ui + Tailwind) for NairaFlow.",
  "license": "MIT",
  "types": "./src/index.ts",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",

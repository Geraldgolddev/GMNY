NODE_ENV=development
APP_NAME=GMNY

POSTGRES_USER=gmny
POSTGRES_PASSWORD=gmny_dev_password_change_me
POSTGRES_DB=gmny
POSTGRES_PORT=5432
DATABASE_URL=postgresql://gmny:gmny_dev_password_change_me@localhost:5432/gmny?schema=public

REDIS_URL=redis://localhost:6379

API_PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

NEXT_PUBLIC_APP_NAME=GMNY
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:4000

# Live FX (Feature 4)
FX_API_URL=https://open.er-api.com/v6/latest/USD

# Circle sandbox (Feature 7)
# SETTLEMENT_PROVIDER=INTERNAL keeps Feature 5 internal settlement.
# Set SETTLEMENT_PROVIDER=CIRCLE to settle the USDC leg via Circle.
SETTLEMENT_PROVIDER=INTERNAL
CIRCLE_MODE=simulate
CIRCLE_CHAIN=BASE_SEPOLIA
CIRCLE_API_BASE_URL=https://api-sandbox.circle.com
# Required only when CIRCLE_MODE=live:
# CIRCLE_API_KEY=
# CIRCLE_ENTITY_SECRET=
# CIRCLE_WALLET_SET_ID=
# CIRCLE_USDC_TOKEN_ID=
# CIRCLE_TREASURY_WALLET_ID=
# CIRCLE_WEBHOOK_SECRET=

# Base network (Feature 8)
BASE_RPC_MODE=simulate
# BASE_RPC_URL=https://sepolia.base.org
# BASE_CHAIN=BASE_SEPOLIA

# Notifications (Feature 9)
# When true, also creates EMAIL channel rows (still delivered via console adapter until SES/Postmark is wired).
NOTIFICATIONS_EMAIL_ENABLED=false

SEED_ADMIN_EMAIL=admin@gmny.com
SEED_ADMIN_PASSWORD=ChangeMeAdmin1!

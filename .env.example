# ─────────────────────────────────────────────────────────────
# GMNY — Root environment template
# Copy to `.env` and adjust. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL="postgresql://gmny:gmny@localhost:5432/gmny?schema=public"
# Used by the e2e test suite
DATABASE_URL_TEST="postgresql://gmny:gmny@localhost:5432/gmny_test?schema=public"

# ── Redis (queues / cache) ───────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── API ──────────────────────────────────────────────────────
API_PORT=4000
API_GLOBAL_PREFIX=api
API_CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ── Auth / JWT ───────────────────────────────────────────────
# Generate with: openssl rand -hex 48
JWT_ACCESS_SECRET="dev-access-secret-change-me-000000000000000000000000000000"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me-11111111111111111111111111111111"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Signing secret for cookies (openssl rand -hex 32)
COOKIE_SECRET="dev-cookie-secret-change-me-222222222222222222222222222222"

# Argon2id password-hashing cost (OWASP-aligned defaults)
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# ── Rate limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ── Security-token lifetimes ─────────────────────────────────
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30

# ── Email (SMTP optional; dev logs links to the console) ─────
MAIL_FROM="GMNY <no-reply@gmny.io>"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# Base URL used to build verification / reset links
APP_WEB_URL="http://localhost:3000"

# ── Blockchain / Circle (Base + USDC) ────────────────────────
CIRCLE_API_KEY=""
CIRCLE_API_BASE_URL="https://api-sandbox.circle.com"
BASE_RPC_URL="https://sepolia.base.org"
USDC_CONTRACT_ADDRESS="0x036CbD53842c5426634e7929541eC2318f3dCF7e"

# ── Web / Admin frontends ────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
WEB_PORT=3000
ADMIN_PORT=3001

# ── App ─────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=GMNY

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=gmny
POSTGRES_PASSWORD=gmny_dev_password_change_me
POSTGRES_DB=gmny
POSTGRES_PORT=5432
DATABASE_URL=postgresql://gmny:gmny_dev_password_change_me@localhost:5432/gmny?schema=public

# ── Redis ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── API ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=4000
API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Auth secrets (min 32 chars) — generate before Phase 1 auth work
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Web / Admin ─────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=GMNY
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:4000
WEB_PORT=3000
ADMIN_PORT=3001

# ── Circle / Base (Phase 2+) ────────────────────────────
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_BASE_URL=https://api.circle.com
BASE_RPC_URL=
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ── Observability ───────────────────────────────────────
LOG_LEVEL=debug
